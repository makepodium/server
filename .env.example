NODE_ENV=development
PORT=3000
HOST=0.0.0.0

POSTGRES_USER=medal
POSTGRES_PASSWORD=change-me-to-a-long-random-value
POSTGRES_DB=medal
DATABASE_URL=postgres://medal:change-me-to-a-long-random-value@localhost:5432/medal

# Object storage. In dev, docker-compose.dev.yml spins up MinIO using
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD as the bucket's access credentials.
MINIO_ROOT_USER=medal
MINIO_ROOT_PASSWORD=change-me-to-a-long-random-value
MINIO_BUCKET=medal

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=medal
S3_ACCESS_KEY=medal
S3_SECRET_KEY=change-me-to-a-long-random-value
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_ENDPOINT=http://localhost:9000

PRESIGNED_TTL_SECONDS=300

# Optional. If set, GET / redirects here (useful when the API host also gets
# random scanner/root hits you'd rather send to a landing page).
# ROOT_REDIRECT_URL=https://example.com
