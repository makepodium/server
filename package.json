{
    "name": "podium-server",
    "version": "0.0.1",
    "private": true,
    "description": "Self-hosted Medal-compatible API",
    "license": "MIT",
    "packageManager": "pnpm@9.12.3",
    "type": "module",
    "scripts": {
        "dev": "tsx watch --env-file=.env src/index.ts",
        "start": "node --env-file=.env dist/index.js",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node scripts/copyTemplates.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "deps:up": "docker compose -f docker-compose.dev.yml up -d",
        "deps:down": "docker compose -f docker-compose.dev.yml down"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.699.0",
        "@aws-sdk/s3-request-presigner": "^3.699.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/sensible": "^6.0.1",
        "@t3-oss/env-core": "^0.13.11",
        "bcrypt": "^5.1.1",
        "drizzle-orm": "^0.36.4",
        "execa": "^9.5.1",
        "fastify": "^5.1.0",
        "fastify-plugin": "^5.1.0",
        "isbot": "^5.1.39",
        "nanoid": "^5.1.9",
        "postgres": "^3.4.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "@types/bcrypt": "^5.0.2",
        "@types/node": "^22.0.0",
        "drizzle-kit": "^0.29.1",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-sonarjs": "^3.0.1",
        "eslint-plugin-unused-imports": "^4.1.4",
        "globals": "^15.14.0",
        "prettier": "^3.8.3",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.19.2",
        "typescript": "^5.6.0",
        "typescript-eslint": "^8.21.0"
    }
}
